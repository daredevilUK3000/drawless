# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it's gitignored.

# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key is SERVER-ONLY. It bypasses row-level security.
# Used by /api/solve to write verified scores. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# The public URL of your deployed app (for magic-link redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
